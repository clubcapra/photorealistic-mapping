<?xml version="1.0" ?>
<!--
  URDF consumed by webots_ros2_driver to expose Rove's Webots devices as ROS 2 topics.
  Device 'reference' values must match the Webots device names in protos/Rove.proto.

  Topic contract MATCHES the real Rove (rove_standard.urdf, 2026-06-01 bag):
    /livox/lidar_192_168_2_40  (sensor_msgs/PointCloud2)
    /livox/lidar_192_168_2_41  (sensor_msgs/PointCloud2)
    /livox/imu_192_168_2_40    (sensor_msgs/Imu, top-MID-360's built-in IMU)
    /cam_north/image_raw  + /cam_north/camera_info  (sensor_msgs/Image, CameraInfo)
    /cam_east/image_raw   + /cam_east/camera_info
    /cam_south/image_raw  + /cam_south/camera_info
    /cam_west/image_raw   + /cam_west/camera_info
    /odom + tf odom -> base_link  (published by RoveDriver from cmd_vel-derived pose)

  Frame names also mirror rove_standard.urdf where practical so RViz config can be
  shared with the real robot. The robot_state_publisher (driven by rove_standard.urdf)
  publishes Core <- ... <- dji_mid360 / chinese_camera_* TFs; we use livox_frame /
  livox_frame_2 in the lidar messages because that's what the Livox driver publishes
  in real life and what KISS-ICP expects.
-->
<robot name="rove">

  <webots>

    <device reference="rove_lidar" type="Lidar">
      <ros>
        <!-- TOP lidar — pose composed from rove_standard.urdf dji_mid360 chain -->
        <topicName>/livox/lidar_192_168_2_40</topicName>
        <alwaysOn>true</alwaysOn>
        <enabled>true</enabled>
        <updateRate>10</updateRate>
        <frameName>livox_frame</frameName>
      </ros>
    </device>

    <device reference="rove_lidar_2" type="Lidar">
      <ros>
        <!-- BOTTOM lidar — pose from rove_standard.urdf dji_mid360_2 chain -->
        <topicName>/livox/lidar_192_168_2_41</topicName>
        <alwaysOn>true</alwaysOn>
        <enabled>true</enabled>
        <updateRate>10</updateRate>
        <frameName>livox_frame_2</frameName>
      </ros>
    </device>

    <device reference="cam_north" type="Camera">
      <ros>
        <topicName>/cam_north/image_raw</topicName>
        <alwaysOn>false</alwaysOn>
        <enabled>true</enabled>
        <updateRate>10</updateRate>
        <frameName>cam_north_optical_frame</frameName>
      </ros>
    </device>
    <device reference="cam_east" type="Camera">
      <ros>
        <topicName>/cam_east/image_raw</topicName>
        <alwaysOn>false</alwaysOn>
        <enabled>true</enabled>
        <updateRate>10</updateRate>
        <frameName>cam_east_optical_frame</frameName>
      </ros>
    </device>
    <device reference="cam_south" type="Camera">
      <ros>
        <topicName>/cam_south/image_raw</topicName>
        <alwaysOn>false</alwaysOn>
        <enabled>true</enabled>
        <updateRate>10</updateRate>
        <frameName>cam_south_optical_frame</frameName>
      </ros>
    </device>
    <device reference="cam_west" type="Camera">
      <ros>
        <topicName>/cam_west/image_raw</topicName>
        <alwaysOn>false</alwaysOn>
        <enabled>true</enabled>
        <updateRate>10</updateRate>
        <frameName>cam_west_optical_frame</frameName>
      </ros>
    </device>

    <device reference="rove_gps" type="GPS">
      <ros>
        <topicName>/rove/gps</topicName>
        <alwaysOn>true</alwaysOn>
        <updateRate>5</updateRate>
        <frameName>base_link</frameName>
      </ros>
    </device>

    <!-- Single IMU triplet at Core, exposed under the real-bag topic name. -->
    <plugin type="webots_ros2_driver::Ros2IMU">
      <enabled>true</enabled>
      <updateRate>200</updateRate>
      <topicName>/livox/imu_192_168_2_40</topicName>
      <alwaysOn>true</alwaysOn>
      <frameName>Core</frameName>
      <inertialUnitName>rove_imu</inertialUnitName>
      <gyroName>rove_gyro</gyroName>
      <accelerometerName>rove_accel</accelerometerName>
    </plugin>

    <!--
      Custom plugin: cmd_vel -> 4-wheel skid-steer motor commands,
      publishes wheel-derived nav_msgs/Odometry on /odom,
      broadcasts tf odom -> base_link and static base_link -> livox_frame / cam_*.
    -->
    <plugin type="rove_sim_webots.rove_driver.RoveDriver">
      <cmd_vel_topic>/cmd_vel</cmd_vel_topic>
      <odom_topic>/odom</odom_topic>
      <wheel_base>0.63</wheel_base>
      <wheel_radius>0.12</wheel_radius>
      <lidar_frame>livox_frame</lidar_frame>
      <base_frame>base_link</base_frame>
      <odom_frame>odom</odom_frame>
      <publish_static_tf>true</publish_static_tf>
      <publish_ground_truth>true</publish_ground_truth>
      <ground_truth_topic>/ground_truth/odom</ground_truth_topic>
      <world_frame>world</world_frame>
    </plugin>
  </webots>

  <!--
    Frames so TF consumers / RViz can resolve them. base_link is the SLAM/nav root.
    Core is the real-Rove URDF root — set identity to base_link so rove_standard.urdf
    TFs (Core <- ... <- dji_mid360_* / chinese_camera_*) all anchor to base_link.
  -->
  <link name="base_link"/>
  <link name="Core"/>
  <joint name="base_to_core" type="fixed">
    <parent link="base_link"/>
    <child link="Core"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
