<?xml version='1.0' encoding='utf-8'?>
<robot name="rove_standard">

  <!-- ============================================================ -->
  <!--  BASE / CHASSIS                                               -->
  <!--  Core is the root — matches rtabmap frame_id=Core.           -->
  <!--  base_link is a child for ROS convention and RViz centering. -->
  <!--  Offset = negated Core.glb centroid [-0.0386, 0.209, 0.115]  -->
  <!-- ============================================================ -->

  <link name="Core">
    <visual>
      <geometry>
        <mesh filename="package://rove_description/meshes/Core.glb" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rove_description/meshes/Core.glb" />
      </geometry>
    </collision>
  </link>

  <joint name="core_to_base_link" type="fixed">
    <parent link="Core"/>
    <child link="base_link"/>
    <origin xyz="-0.0386 0.2090 0.1150" rpy="0 0 0"/>
  </joint>
  <link name="base_link"/>

  <!-- ============================================================ -->
  <!--  DRIVE DRUMS  (4x)                                           -->
