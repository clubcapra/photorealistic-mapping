<?xml version='1.0' encoding='utf-8'?>
<robot name="rove_standard">

  <!-- ============================================================ -->
  <!--  BASE / CHASSIS                                               -->
  <!-- ============================================================ -->

  <link name="Core">
    <visual>
      <geometry>
        <mesh filename="package://rove_description/meshes/Core.glb" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rove_description/meshes/Core.glb" />
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!--  DRIVE DRUMS  (4x – each uses a pivot/offset pattern)        -->
  <!-- ============================================================ -->

  <!-- Front-Left Drum -->
  <joint name="drum_fl_joint" type="revolute">
    <origin xyz="-0.299777 0.149 0.0888089" rpy="0 0 0" />
    <parent link="Core" />
    <child link="drum_fl_pivot" />
    <axis xyz="0 -1 0" />
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1" />
  </joint>
  <link name="drum_fl_pivot" />
  <joint name="drum_fl_offset" type="fixed">
    <origin xyz="0.299777 -0.149 -0.0888089" rpy="0 0 0" />
    <parent link="drum_fl_pivot" />
    <child link="DrumFL" />
