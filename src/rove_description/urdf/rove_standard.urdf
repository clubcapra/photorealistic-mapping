    <child link="chinese_camera_5" />
  </joint>
  <link name="chinese_camera_5">
    <visual>
      <geometry>
        <mesh filename="package://rove_description/meshes/chinese_camera_5.glb" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rove_description/meshes/chinese_camera_5.glb" />
      </geometry>
    </collision>
  </link>

  <!-- Front body camera (faces +X side of Core, near pole base) -->
  <joint name="cam_body_front_joint" type="fixed">
    <origin xyz="0.31746 0.209 0.192576" rpy="0 0 0" />
    <parent link="Core" />
    <child link="cam_body_front_pivot" />
    <axis xyz="1 0 0" />
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1" />
  </joint>
  <link name="cam_body_front_pivot" />
  <joint name="cam_body_front_offset" type="fixed">
    <origin xyz="0.031733 -0.000947911 -0.0166233" rpy="-1.5708 5.55112e-17 1.5708" />
    <parent link="cam_body_front_pivot" />
    <child link="chinese_camera_6" />
  </joint>
  <link name="chinese_camera_6">
    <visual>
      <geometry>
        <mesh filename="package://rove_description/meshes/chinese_camera_6.glb" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rove_description/meshes/chinese_camera_6.glb" />
      </geometry>
    </collision>
  </link>

  <!-- Gripper camera (mounted on JointGripper) -->
  <joint name="cam_gripper_joint" type="fixed">
    <origin xyz="-1.1936 0.205 0.4155" rpy="0 0 0" />
    <parent link="JointGripper" />
    <child link="cam_gripper_pivot" />
    <axis xyz="0 -0.111961 0.993713" />
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1" />
  </joint>
  <link name="cam_gripper_pivot" />
  <joint name="cam_gripper_offset" type="fixed">
    <origin xyz="0.00311921 6.66671e-05 0.0217355" rpy="-1.5708 -5.55112e-17 -1.5708" />
    <parent link="cam_gripper_pivot" />
    <child link="chinese_camera_7" />
  </joint>
  <link name="chinese_camera_7">
    <visual>
      <geometry>
        <mesh filename="package://rove_description/meshes/chinese_camera_7.glb" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rove_description/meshes/chinese_camera_7.glb" />
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!--  IMU  (VectorNav VN-300, fixed to Core)                      -->
  <!-- ============================================================ -->

  <joint name="imu_joint" type="fixed">
    <parent link="Core" />
    <child link="vn300_vectornav" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  <link name="vn300_vectornav">
    <visual>
      <geometry>
        <mesh filename="package://rove_description/meshes/vn300_vectornav.glb" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rove_description/meshes/vn300_vectornav.glb" />
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!--  CAMERA OPTICAL FRAMES                                        -->
  <!--  (Z points in the direction the camera faces)                -->
  <!-- ============================================================ -->

  <!-- cam_west: faces -Y in world → optical Z must point -Y -->
  <joint name="cam_west_optical_joint" type="fixed">
    <parent link="chinese_camera_2"/>
    <child link="cam_west_optical_frame"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- cam_north: faces +X in world → optical Z must point +X -->
  <joint name="cam_north_optical_joint" type="fixed">
    <parent link="chinese_camera"/>
    <child link="cam_north_optical_frame"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- cam_east: faces +Y in world → optical Z must point +Y -->
  <joint name="cam_east_optical_joint" type="fixed">
    <parent link="chinese_camera_4"/>
    <child link="cam_east_optical_frame"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- cam_south: faces -X in world → optical Z must point -X -->
  <joint name="cam_south_optical_joint" type="fixed">
    <parent link="chinese_camera_3"/>
    <child link="cam_south_optical_frame"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="cam_west_optical_frame"/>
  <link name="cam_north_optical_frame"/>
  <link name="cam_east_optical_frame"/>
  <link name="cam_south_optical_frame"/>

</robot>
