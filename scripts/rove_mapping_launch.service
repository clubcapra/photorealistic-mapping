[Unit]
Description=Launches all nodes required for the mapping or Rove

[Service]
Environment="ROS_LOG_DIR=/mnt/ssd/sftp/log/ros2"
Environment="ROS_DOMAIN_ID=96"
ExecStart=/bin/bash -c "source /home/capra/projects/photorealistic-mapping/install/setup.bash && ros2 launch rove_color_mapping run.launch.py"
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
